<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/fragment_menu_main"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/zalith_bg">

	<LinearLayout
		android:id="@+id/live_info_bar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@color/glass_effect"
		android:padding="12dp"
		android:orientation="horizontal"
		app:layout_constraintTop_toTopOf="parent">

		<TextView
			android:id="@+id/ping_text"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="● 45ms"
			android:textColor="@color/zalith_accent"
			android:textStyle="bold"
			android:textSize="12sp" />

		<TextView
			android:id="@+id/battery_text"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginStart="20dp"
			android:text="BATTERY: 85%"
			android:textColor="#FFFFFF"
			android:textSize="12sp" />
	</LinearLayout>

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:paddingHorizontal="15dp"
		app:layout_constraintTop_toBottomOf="@id/live_info_bar"
		app:layout_constraintBottom_toTopOf="@id/version_card">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:paddingTop="15dp">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">
				<com.kdt.mcgui.LauncherMenuButton
					android:id="@+id/news_button"
					android:layout_width="0dp"
					android:layout_height="60dp"
					android:layout_weight="1"
					android:text="WIKI"
					android:background="@drawable/zalith_button_bg" />
				<View android:layout_width="10dp" android:layout_height="1dp"/>
				<com.kdt.mcgui.LauncherMenuButton
					android:id="@+id/discord_button"
					android:layout_width="0dp"
					android:layout_height="60dp"
					android:layout_weight="1"
					android:text="DISCORD"
					android:background="@drawable/zalith_button_bg" />
			</LinearLayout>

			<com.kdt.mcgui.LauncherMenuButton
				android:id="@+id/custom_control_button"
				android:layout_width="match_parent"
				android:layout_height="65dp"
				android:layout_marginTop="12dp"
				android:text="CUSTOM CONTROLS"
				android:background="@drawable/zalith_button_bg" />

			<com.kdt.mcgui.LauncherMenuButton
				android:id="@+id/install_jar_button"
				android:layout_width="match_parent"
				android:layout_height="65dp"
				android:layout_marginTop="10dp"
				android:text="INSTALL JAR"
				android:background="@drawable/zalith_button_bg" />

			<com.kdt.mcgui.LauncherMenuButton
				android:id="@+id/open_files_button"
				android:layout_width="match_parent"
				android:layout_height="65dp"
				android:layout_marginTop="10dp"
				android:text="FILES MANAGER"
				android:background="@drawable/zalith_button_bg" />

		</LinearLayout>
	</ScrollView>

	<androidx.cardview.widget.CardView
		android:id="@+id/version_card"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_margin="15dp"
		tools:cardBackgroundColor="@color/zalith_card"
		tools:cardCornerRadius="20dp"
		app:layout_constraintBottom_toTopOf="@id/play_button">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="10dp"
			android:gravity="center_vertical">

			<com.kdt.mcgui.mcVersionSpinner
				android:id="@+id/mc_version_spinner"
				android:layout_width="0dp"
				android:layout_height="55dp"
				android:layout_weight="1"
				android:background="@android:color/transparent" />

			<ImageButton
				android:id="@+id/edit_profile_button"
				android:layout_width="55dp"
				android:layout_height="55dp"
				android:background="?android:attr/selectableItemBackground"
				android:src="@drawable/ic_edit_profile"
				app:tint="@color/zalith_accent" />
		</LinearLayout>
	</androidx.cardview.widget.CardView>

	<com.kdt.mcgui.MineButton
		android:id="@+id/play_button"
		android:layout_width="match_parent"
		android:layout_height="75dp"
		android:layout_marginHorizontal="20dp"
		android:layout_marginBottom="20dp"
		android:text="LAUNCH ENGINE"
		android:textColor="#000000"
		android:textStyle="bold"
		android:textSize="18sp"
		android:backgroundTint="@color/zalith_accent"
		app:layout_constraintBottom_toBottomOf="parent" />

    <Button android:id="@+id/share_logs_button" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
